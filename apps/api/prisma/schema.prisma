// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Users ────────────────────────────────────────────────────────────────────

/// An authenticated user account. Passwords are hashed with Argon2id.
/// Role is either "admin" (full access) or "viewer" (read-only presentation mode).
model User {
  id                  String    @id @default(uuid())
  email               String    @unique
  passwordHash        String    @map("password_hash")
  role                UserRole  @default(viewer)
  isEnabled           Boolean   @default(true) @map("is_enabled")
  failedLoginAttempts  Int       @default(0) @map("failed_login_attempts")
  lockedAt             DateTime? @map("locked_at")
  requiresPasswordReset Boolean  @default(false) @map("requires_password_reset")
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  revisions RevisionHistory[]

  @@map("users")
}

/// Email addresses permitted to register. New accounts are rejected unless the
/// email is present in this table (or the account is created directly by an admin).
model AllowedEmail {
  id        String   @id @default(uuid())
  email     String   @unique
  role      UserRole @default(viewer)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("allowed_emails")
}

enum UserRole {
  admin
  viewer
}

// ─── Dashboards ───────────────────────────────────────────────────────────────

/// A named dashboard that groups one or more floorplans.
/// Exactly one dashboard should have isDefault = true; it is loaded on the
/// root presentation route ("/").
model Dashboard {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  floorplans Floorplan[]

  @@map("dashboards")
}

// ─── Floorplans ───────────────────────────────────────────────────────────────

/// A floorplan image canvas that belongs to a Dashboard.
/// imageMode controls which image is shown:
///   "single"          – always use imageAssetId
///   "day_night_cycle" – pick from cycleImagesJson arrays based on solar position
///   "none"            – solid backgroundColor only
/// heatmapMaskAssetId references a PNG where white pixels mark interior area;
/// used by temperature_gauge hotspots to draw the radial heat overlay.
model Floorplan {
  id                  String   @id @default(uuid())
  dashboardId         String   @map("dashboard_id")
  name                String
  imageMode           String   @default("single") @map("image_mode")
  imageStretch        Boolean  @default(true) @map("image_stretch")
  imageAssetId        String?  @map("image_asset_id")
  cycleImagesJson     Json     @default("{}") @map("cycle_images_json")
  width               Int      @default(1920)
  height              Int      @default(1080)
  backgroundColor     String   @default("#1a1a1a") @map("background_color")
  heatmapMaskAssetId  String?  @map("heatmap_mask_asset_id")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  dashboard        Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  imageAsset       Asset?    @relation("FloorplanImage", fields: [imageAssetId], references: [id])
  heatmapMaskAsset Asset?    @relation("HeatmapMask", fields: [heatmapMaskAssetId], references: [id])
  hotspots         Hotspot[]

  @@map("floorplans")
}

// ─── Hotspots ─────────────────────────────────────────────────────────────────

/// An interactive element overlaid on a Floorplan.
/// Position fields (x, y, width, height) are normalized 0–1 fractions of
/// the floorplan canvas dimensions so they scale correctly at any resolution.
/// configJson stores type-specific settings; its shape is defined by the
/// corresponding *Config interface in packages/shared/src/types.ts.
/// entityId links to a Home Assistant entity whose live state drives rendering.
model Hotspot {
  id          String      @id @default(uuid())
  floorplanId String      @map("floorplan_id")
  name        String
  type        HotspotType
  // Normalized position (0-1 range)
  x           Float       @default(0.5)
  y           Float       @default(0.5)
  width       Float       @default(0.1)
  height      Float       @default(0.1)
  rotation    Float       @default(0)
  zIndex      Int         @default(0) @map("z_index")
  entityId    String?     @map("entity_id")
  // Type-specific configuration stored as JSON
  configJson  Json        @default("{}") @map("config_json")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  floorplan  Floorplan          @relation(fields: [floorplanId], references: [id], onDelete: Cascade)
  stateRules HotspotStateRule[]

  @@map("hotspots")
}

enum HotspotType {
  action
  text
  state_image
  state_icon
  badge
  scene
  blind
  bins
  custom
  weather
  temperature_gauge
  windrose
  battery
  clock
  burn_off
}

// ─── Hotspot State Rules ──────────────────────────────────────────────────────

/// A conditional rule that overrides a Hotspot's appearance when its bound
/// entity matches the condition. Rules are evaluated in ascending priority
/// order; the first match wins. conditionJson and resultJson are typed by
/// Condition and RuleResult in packages/shared/src/types.ts.
model HotspotStateRule {
  id            String   @id @default(uuid())
  hotspotId     String   @map("hotspot_id")
  priority      Int      @default(0)
  conditionType String   @map("condition_type")
  conditionJson Json     @map("condition_json")
  resultJson    Json     @map("result_json")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  hotspot Hotspot @relation(fields: [hotspotId], references: [id], onDelete: Cascade)

  @@map("hotspot_state_rules")
}

// ─── Assets ───────────────────────────────────────────────────────────────────

/// An uploaded image or icon file. The file itself is stored on disk at
/// storagePath (within ASSET_STORAGE_PATH). Accepted types: SVG, PNG, WebP,
/// JPEG, GIF. width and height are populated at upload time for raster images.
/// Assets may be referenced by Floorplan.imageAssetId, heatmapMaskAssetId,
/// cycleImagesJson, and hotspot configJson fields.
model Asset {
  id           String   @id @default(uuid())
  filename     String   @unique
  originalName String   @map("original_name")
  mimeType     String   @map("mime_type")
  sizeBytes    Int      @map("size_bytes")
  storagePath  String   @map("storage_path")
  width        Int?
  height       Int?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  floorplans        Floorplan[] @relation("FloorplanImage")
  heatmapFloorplans Floorplan[] @relation("HeatmapMask")

  @@map("assets")
}

// ─── App Settings ─────────────────────────────────────────────────────────────

/// Key/value store for application-wide settings (theme, PIN, inactivity
/// timeout, etc.). valueJson holds any JSON-serialisable value.
model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  valueJson Json     @map("value_json")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// ─── Revision History ─────────────────────────────────────────────────────────

/// Immutable audit log written on every create, update, or delete of a
/// Hotspot, Floorplan, or Dashboard. beforeJson / afterJson capture the full
/// record state before and after the change. Indexed on (entityType, entityId)
/// for efficient per-entity history queries.
model RevisionHistory {
  id         String          @id @default(uuid())
  entityType String          @map("entity_type")
  entityId   String          @map("entity_id")
  action     RevisionAction
  beforeJson Json?           @map("before_json")
  afterJson  Json?           @map("after_json")
  userId     String?         @map("user_id")
  createdAt  DateTime        @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@map("revision_history")
}

enum RevisionAction {
  create
  update
  delete
}
