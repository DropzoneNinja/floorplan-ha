    "archiver": "^7.0.1",
    "argon2": "^0.41.0",
    "fastify": "^5.0.0",
    "jose": "^5.0.0",
    "sharp": "^0.34.5",
    "unzipper": "^0.12.3",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
