# ─────────────────────────────────────────────────────────────
# HomePlan HA — Environment Variables
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ─── Node ─────────────────────────────────────────────────────
NODE_ENV=development

# ─── Ports ────────────────────────────────────────────────────
APP_PORT=5173
API_PORT=3001

# ─── Database ─────────────────────────────────────────────────
# Full Postgres connection string (used by Prisma)
DATABASE_URL=postgresql://floorplan:secret@localhost:5432/floorplan_ha

# Individual Postgres credentials (used by Docker Compose to init the DB)
POSTGRES_USER=floorplan
POSTGRES_PASSWORD=secret
POSTGRES_DB=floorplan_ha

# ─── Auth ─────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 32
SESSION_SECRET=CHANGE_ME_generate_a_32_char_secret

# ─── Home Assistant ───────────────────────────────────────────
# URL of your Home Assistant instance (no trailing slash)
HA_BASE_URL=http://homeassistant.local:8123

# Long-lived access token from your HA profile
# NEVER expose this to the frontend — backend only
HA_TOKEN=YOUR_HA_LONG_LIVED_TOKEN_HERE

# ─── Asset Storage ────────────────────────────────────────────
# Host path where uploaded images are stored. This is bind-mounted into the
# container at /uploads, so files are written directly to the host OS.
# Use an absolute path, e.g. /mnt/nas/floorplan-uploads or /home/user/uploads
ASSET_STORAGE_PATH=/path/to/your/uploads

# ─── Backup Storage ───────────────────────────────────────────
# Host path where backup zip files are stored. This is bind-mounted into the
# container at /backups, so backups are written directly to the host OS.
# Use an absolute path, e.g. /mnt/nas/floorplan-backups or /home/user/backups
BACKUP_STORAGE_PATH=/path/to/your/backups

# ─── CORS ─────────────────────────────────────────────────────
# Frontend origin allowed to call the API
CORS_ORIGIN=http://localhost:5173

# ─── Seed (optional) ──────────────────────────────────────────
# Used by prisma/seed.ts to create the initial admin user
ADMIN_EMAIL=admin@localhost
ADMIN_PASSWORD=changeme123
